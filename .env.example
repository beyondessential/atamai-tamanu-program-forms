# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Questions skill — RAG (optional; leave unset to use stdio mode with a local sibling repo)
# RAG_MCP_URL=https://your-rag-mcp-server/
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# To switch LLM providers, edit baml_src/clients.baml and set the key here, e.g.:
# OPENAI_API_KEY=sk-...
